auto-install-peers=true
strict-peer-dependencies=false
# M_AUDIT2.SEC2.14 — block postinstall/preinstall/etc scripts in
# transitive deps. Supply-chain compromise vector: a malicious dep
# update lands a postinstall script that runs arbitrary code on
# `pnpm install`. With this flag pnpm refuses to run lifecycle scripts
# from packages not in the onlyBuiltDependencies allowlist
# (declared in package.json).
enable-pre-post-scripts=false
