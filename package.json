{
  "name": "aethelgard-chronicles-of-strata",
  "private": true,
  "version": "0.1.20",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "copywasm": "node scripts/copy-wasm.mjs",
    "predev": "pnpm copywasm",
    "prebuild": "pnpm copywasm",
    "pretest:browser": "pnpm copywasm",
    "pretest:e2e": "pnpm copywasm",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:pages": "tsc && vite build --mode github-pages",
    "build:native": "pnpm build && cap sync",
    "preview": "vite preview --port 8080",
    "check": "tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:eslint": "eslint src",
    "format:md": "prettier --write '**/*.{md,yml,yaml}'",
    "format:md:check": "prettier --check '**/*.{md,yml,yaml}'",
    "lighthouse": "lhci autorun",
    "docs": "typedoc",
    "lint:md": "markdownlint '**/*.md' --ignore-path .markdownlintignore",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:browser": "vitest run --project browser",
    "visual:battery": "node scripts/visual-battery.mjs",
    "visual:battery:ci": "node scripts/visual-battery.mjs --ci",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:multiview": "MULTIVIEW=1 playwright test",
    "test:e2e:visual": "VISUAL=1 playwright test",
    "test:e2e:update": "VISUAL=1 playwright test --update-snapshots",
    "test:e2e:journey": "JOURNEY=1 playwright test",
    "visual:fixtures": "node scripts/capture-aethelgard-fixtures.mjs",
    "test:maestro": "maestro test .maestro/smoke.yaml",
    "test:maestro:all": "maestro test .maestro/",
    "test:maestro:menu": "maestro test .maestro/menu-to-onboarding.yaml",
    "test:maestro:drawer": "maestro test .maestro/system-menu-drawer.yaml",
    "test:maestro:nplayer": "maestro test .maestro/nplayer-setup.yaml",
    "test:maestro:gameover": "maestro test .maestro/game-over.yaml",
    "assets:manifest": "tsx scripts/build-manifest.ts",
    "assets:measure": "node scripts/measure-glbs.mjs",
    "cap": "cap",
    "cap:sync": "pnpm build && cap sync",
    "cap:run:android": "cap run android",
    "verify": "pnpm check && pnpm lint && pnpm format:check && pnpm test",
    "verify:all": "pnpm verify && pnpm test:browser",
    "release:dry-run": "tsx scripts/release-dry-run.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/core": "8.3.4",
    "@capacitor/device": "8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/preferences": "8.0.1",
    "@fontsource/inter": "5.2.8",
    "@fontsource/metamorphous": "5.2.8",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@react-three/postprocessing": "3.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "clsx": "^2.1.1",
    "framer-motion": "12.40.0",
    "howler": "2.2.4",
    "jeep-sqlite": "2.8.0",
    "koota": "0.6.6",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "postprocessing": "6.39.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "seedrandom": "3.0.5",
    "sql.js": "1.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "three": "0.184.0",
    "tw-animate-css": "^1.4.0",
    "yuka": "0.7.8",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@capacitor/android": "8.3.4",
    "@capacitor/cli": "8.3.4",
    "@capacitor/ios": "8.3.4",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@gltf-transform/core": "4.3.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.60.0",
    "@types/howler": "2.2.13",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/seedrandom": "3.0.8",
    "@types/sql.js": "1.4.11",
    "@types/three": "0.184.1",
    "@types/yuka": "0.7.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "axe-core": "^4.11.4",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.48.0",
    "playwright": "1.60.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "4.22.3",
    "typedoc": "^0.28.19",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-static-assets-plugin": "1.2.2",
    "vitest": "4.1.7",
    "vitest-browser-react": "2.2.0"
  }
}
