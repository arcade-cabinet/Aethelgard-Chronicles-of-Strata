{
  "name": "aethelgard-chronicles-of-strata",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "copywasm": "node scripts/copy-wasm.mjs",
    "predev": "pnpm copywasm",
    "prebuild": "pnpm copywasm",
    "pretest:browser": "pnpm copywasm",
    "pretest:e2e": "pnpm copywasm",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:pages": "tsc && vite build --mode github-pages",
    "build:native": "pnpm build && cap sync",
    "preview": "vite preview --port 8080",
    "check": "tsc",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:browser": "vitest run --project browser",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "assets:manifest": "tsx scripts/build-manifest.ts",
    "cap": "cap",
    "cap:sync": "pnpm build && cap sync",
    "cap:run:android": "cap run android",
    "verify": "pnpm check && pnpm lint && pnpm format:check && pnpm test",
    "release:dry-run": "tsx scripts/release-dry-run.ts"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/core": "8.3.4",
    "@capacitor/device": "8.0.2",
    "@capacitor/preferences": "8.0.1",
    "@fontsource/inter": "5.2.8",
    "@fontsource/metamorphous": "5.2.8",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "framer-motion": "12.40.0",
    "howler": "2.2.4",
    "jeep-sqlite": "2.8.0",
    "koota": "0.6.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "seedrandom": "3.0.5",
    "sql.js": "1.11.0",
    "three": "0.184.0",
    "yuka": "0.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@capacitor/android": "8.3.4",
    "@capacitor/cli": "8.3.4",
    "@capacitor/ios": "8.3.4",
    "@gltf-transform/core": "4.3.0",
    "@playwright/test": "1.60.0",
    "@types/howler": "2.2.13",
    "@types/node": "22.19.19",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/seedrandom": "3.0.8",
    "@types/sql.js": "1.4.11",
    "@types/three": "0.184.1",
    "@types/yuka": "0.7.4",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "playwright": "1.60.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-static-assets-plugin": "1.2.2",
    "vitest": "4.1.7",
    "vitest-browser-react": "2.2.0"
  }
}
