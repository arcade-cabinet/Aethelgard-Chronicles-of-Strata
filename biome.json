{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**",
      "!dist",
      "!public/assets",
      "!android",
      "!.vite",
      "!coverage",
      "!src/static-assets.ts",
      "!.claude/worktrees",
      "!.clone"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "error" },
      "correctness": { "noUnusedVariables": "error" }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "single", "trailingCommas": "all" }
  },
  "overrides": [
    {
      "includes": [
        "src/entities/**",
        "src/world/**",
        "src/render/**",
        "!src/world/TileInteraction.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": "off"
        }
      }
    }
  ]
}
