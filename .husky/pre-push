#!/usr/bin/env sh
# M_POLISH3.LOCAL.1 — pre-push gate.
# Run the full verify suite + e2e battery BEFORE pushing.
# Catches every CI failure on the local machine.
# Skip with `git push --no-verify` only when explicitly authorized.

set -e

# M_NEXT.PROC.1 — skip when the push contains only deletions.
# git pre-push receives ref lines on stdin in the form:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
# A deletion is local-sha = 40 zeros. If EVERY input line is a
# deletion, there's nothing to gate against — running verify on
# the deletion-only push burns 3-5 minutes for no benefit.
deletion_only=true
while read -r _local_ref local_sha _remote_ref _remote_sha; do
  if [ -z "$local_sha" ]; then continue; fi
  case "$local_sha" in
    0000000000000000000000000000000000000000) : ;;
    *) deletion_only=false ;;
  esac
done

if [ "$deletion_only" = "true" ]; then
  echo "[pre-push] deletion-only push detected — skipping verify gate."
  exit 0
fi

echo "[pre-push] running pnpm verify..."
pnpm verify

echo "[pre-push] running pnpm test:browser..."
# M_HUD.SHELL.21 — vitest browser-mode shares Playwright Chromium across
# parallel test files; harness tests (biome-swatch, n-player-picker,
# wildfire/volcano layers) occasionally collide on the worker pool.
# Retry once on failure — both passes failing = a genuine regression.
pnpm test:browser || {
  echo "[pre-push] test:browser flaked — retrying once..."
  pnpm test:browser
}

echo "[pre-push] running pnpm test:e2e..."
# M_V13.PROC.E2E-RETRY — mirror the test:browser retry pattern. The
# save-load-n-player + AI-vs-AI specs occasionally hit SuspenseProbe
# stalls (43s+ asset suspend on cold Vite cache); a clean retry succeeds.
# Both passes failing = a genuine regression.
PW_REUSE_SERVER=1 pnpm test:e2e || {
  echo "[pre-push] test:e2e flaked — retrying once..."
  PW_REUSE_SERVER=1 pnpm test:e2e
}

echo "[pre-push] all gates green — push proceeding."
